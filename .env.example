# 강릉봄푸드페스타 (GNfesta) 환경변수 템플릿
# 로컬 개발용: 이 파일을 복사해 `.env` 로 저장한 뒤 실제 값을 입력.
# Vercel: 프로젝트 Settings → Environment Variables 에 각 항목 등록.

# ─── Supabase (프론트/서버 공통) ───
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── 개발 모드 플래그 (prod 에서는 설정하지 않음) ───
# VITE_DEV_MODE=true

# ─── 토스페이먼츠 (결제 연동 필수) ───
# Toss 개발자센터 → 내 개발정보 에서 발급
#  - VITE_TOSS_CLIENT_KEY : 클라이언트 SDK 용 (공개 OK). customer 앱에서만 사용.
#  - TOSS_SECRET_KEY      : 서버 전용 (Basic Auth). 절대 클라에 노출 금지.
VITE_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxx

# ─── AR 모듈 에셋 베이스 URL (Phase 2+) ───
# 미설정 시 Khronos 공개 샘플 CDN 사용 (Phase 2 플레이스홀더 모드).
# R2 배포 시 예: https://ar-assets.gnfesta.com/ (끝에 슬래시 유무 상관 없음)
VITE_AR_ASSETS_BASE_URL=
